#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D C:\docAiGen\Manuali_SW3_SW4\mcu\dev\build && "C:\Program Files\CMake\bin\cmake-gui.exe" -SC:\docAiGen\Manuali_SW3_SW4\mcu\dev -BC:\docAiGen\Manuali_SW3_SW4\mcu\dev\build"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D C:\docAiGen\Manuali_SW3_SW4\mcu\dev\build && "C:\Program Files\CMake\bin\cmake.exe" --regenerate-during-build -SC:\docAiGen\Manuali_SW3_SW4\mcu\dev -BC:\docAiGen\Manuali_SW3_SW4\mcu\dev\build"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

