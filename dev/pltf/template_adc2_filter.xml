<!-- Filter Template -->
<!-- Parameters: -->
<!--   FILTIDX: filter index, range 0..7 -->
<ifxmlcfg version="2.6.2">
  <checksum>31de5490a4061bee4edff36c511fab10ce095df4f2000bfad42336c00e5094fe</checksum>
  <version label="V0.0.4"/>
  <usesPython/>
  <treecontainer headerlabels="Item;Value;" label="Filter $FILTIDX$" define="ADC2.FILT$FILTIDX$CONT" desc="Filter Channel $FILTIDX$" columnwidths="300;300" enabled="false">
    <header file="adc2_defines.h">
      <!-- Variables -->
      <edit label="Used by Channel" readonly="1" define="ADC2.FILT$FILTIDX$_USED_TXT" svd="0" default="not assigned" header="temp_defines.h"/>
      <!-- Configuration -->
      <combo label="Filter Coefficient" define="ADC2.FILTCFG.COEF_A$FILTIDX$">
        <item label="1/2" override="value1"/>
        <item label="1/4" override="value2"/>
        <item label="1/8" override="value3"/>
        <item label="1/16" override="value4"/>
      </combo>
    </header>
  </treecontainer>
</ifxmlcfg>
