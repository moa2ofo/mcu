          <text size="400;-1" label="Callback function"/>
        </horizontalcontainer>
        <horizontalcontainer define="MEMCTRL.NVM0_OP_COMPLETE_INT_BOX" visible="false">
          <text size="200;-1" label="NVM0 Operation Complete"/>
          <math size="75;-1" formula="6"/>
          <math size="75;-1" formula="MEMCTRL.IEN.NVM0OPCIEN"/>
          <edit size="400;-1" define="RO_MEMCTRL.NVM0_OP_COMPLETE_CALLBACK" svd="0" readonly="1" default=""/>
        </horizontalcontainer>
        <horizontalcontainer define="MEMCTRL.NVM1_OP_COMPLETE_INT_BOX" visible="false">
          <text size="200;-1" label="NVM1 Operation Complete"/>
          <math size="75;-1" formula="6"/>
          <math size="75;-1" formula="MEMCTRL.IEN.NVM1OPCIEN"/>
          <edit size="400;-1" define="RO_MEMCTRL.NVM1_OP_COMPLETE_CALLBACK" svd="0" readonly="1" default=""/>
