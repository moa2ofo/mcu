  <version label="V0.1.5"/>
  <usesPython/>
  <header file="">
    <verticalcontainer size="800;-1" stretch="2">
      <text label="Configured Interrupts of Nodes 6"/>
      <verticalcontainer label="Timer and Math" visible="false">
        <timer visible="true" define="MEMCTRL_FILL_INT_OVERVIEW" interval="1" singleShot="1" run="0">
          <action event="changed" cmd="setDef" data="RO_MEMCTRL.NVM0_OP_COMPLETE_CALLBACK=MEMCTRL.NVM0_OP_COMPLETE_CALLBACK"/>
          <action event="changed" cmd="setDef" data="RO_MEMCTRL.NVM1_OP_COMPLETE_CALLBACK=MEMCTRL.NVM1_OP_COMPLETE_CALLBACK"/>
        </timer>
        <math formula="MEMCTRL.NVM0_OP_COMPLETE_INT_EN"><action event="changed" cmd="setDef" data="MEMCTRL.NVM0_OP_COMPLETE_INT_BOX.visible=MEMCTRL.NVM0_OP_COMPLETE_INT_EN"/></math>
        <math formula="MEMCTRL.NVM1_OP_COMPLETE_INT_EN"><action event="changed" cmd="setDef" data="MEMCTRL.NVM1_OP_COMPLETE_INT_BOX.visible=MEMCTRL.NVM1_OP_COMPLETE_INT_EN"/></math>
      </verticalcontainer> <!-- Timer and Math -->
      <verticalcontainer label="Interrupt Overview ">
        <horizontalcontainer>
          <text size="200;-1" label="Interrupt"/>
          <text size="75;-1" label="Int. Node"/>
