<!-- Calibration Template -->
<!-- Parameter:           -->
<!--   IDX, analog input index, range 0..26 -->
<!--   TXT, analog input select -->
<ifxmlcfg version="2.6.2">
  <checksum>529b67982c3b42437a7d8fea6916a8589399270a99430a0a0f7237a4a24c062f</checksum>
  <version label="V0.2.3"/>
  <usesPython/>
  <groupcontainer define="ADC1.CALIBCONT_AI$IDX$" headerlabels="Item;Value;" size="-1;115" label="Calibration" columnwidths="250;300;1" visible="false" font="Source Sans Pro,12,0,0,100,0,0,0,0,0" color="206;217;164">
    <header file="adc1_defines.h">
      <verticalcontainer>
        <horizontalcontainer>
          <text label="Enable Calibration for input $TXT$"/>
          <checkbox define="ADC1.CALIB$IDX$_EN" svd="0" label="Enable Calibration" header="temp_defines.h"/>
          <math define="ADC1.CALEN[$IDX$]" visible="false" formula="ADC1.CALIB$IDX$_EN"/>
        </horizontalcontainer>
        <horizontalcontainer>
          <text label="The gain is determined individually per chip and preloaded by the BootROM at startup."/>
        </horizontalcontainer>
        <horizontalcontainer>
          <text label="The offset is determined individually per chip and preloaded by the BootROM at startup."/>
        </horizontalcontainer>
      </verticalcontainer>
    </header>
  </groupcontainer>
</ifxmlcfg>
