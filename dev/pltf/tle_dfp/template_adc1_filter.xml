<!-- Filter Template -->
<!-- Parameters: -->
<!--   IDX: filter index, range 0..3 -->
<ifxmlcfg version="2.6.2">
  <checksum>7be837ad4a2d3e74824a29a50d79fb4f19e9554a9b44c1b591e0d22387be7c05</checksum>
  <version label="V0.2.3"/>
  <usesPython/>
  <treecontainer headerlabels="Item;Value;" label="Filter $IDX$" define="ADC1.FILT$IDX$CONT" desc="Filter Channel $IDX$" columnwidths="250;300;1" enabled="false">
    <header file="adc1_defines.h">
      <var define="ADC1.FILT$IDX$_USED_BY" svn="0" default="255" header="temp_defines.h"/>
      <edit label="Used by Channel" readonly="1" define="ADC1.FILT$IDX$_USED_BY_TXT" svd="0" default="not assigned" header=""/>
      <combo label="Filter Coefficient" define="ADC1.FILTCFG.COEF_A$IDX$">
        <item label="1/2" override="value1"/>
        <item label="1/4" override="value2"/>
        <item label="1/8" override="value3"/>
        <item label="1/16" override="value4"/>
      </combo>
    </header>
  </treecontainer>
</ifxmlcfg>
