<!-- HB_IDX Half-bridge number -->
<!-- CYCLE Charge or Discharge -->
<!-- ONOFF On or Off -->
<!-- PHASE Phase number -->
<!-- DEFAULT Default value -->
<ifxmlcfg version="2.6.2">
  <checksum>6aceb4acb781843e4732c7615dacb2503ff04953062233c46f7ae7f7f8d122b0</checksum>
  <version label="V0.1.7"/>
  <usesPython/>
  <horizontalcontainer define="BDRV.HB$HB_IDX$_I$PHASE$$CYCLE$SEQ_CONT" size="350;-1">
    <header file="bdrv_defines.h">
      <spinbox label="Phase $PHASE$ - Current [5mA - 350mA]" define="BDRV.HS$HB_IDX$SEQ$ONOFF$IC_HS$HB_IDX$_I$PHASE$$ONOFF$" default="$DEFAULT$" range="5;350" svd="0" size="70;-1" header="temp_defines.h">
        <action event="changed" cmd="setDef" data="BDRV_UPDATE.run=1"/>
      </spinbox>
      <text label="Reg:" size="35;-1"/>
      <math label="Register Value" define="BDRV.HS$HB_IDX$SEQ$ONOFF$IC_HS$HB_IDX$_I$PHASE$$ONOFF$_MATH" svd="0" format="%1X" formula="round(63*((BDRV.HS$HB_IDX$SEQ$ONOFF$IC_HS$HB_IDX$_I$PHASE$$ONOFF$-5)/345)^0.671)" header="temp_defines.h"/>
      <spinbox label="Phase $PHASE$ - Current [5mA - 350mA]" define="BDRV.LS$HB_IDX$SEQ$ONOFF$IC_LS$HB_IDX$_I$PHASE$$ONOFF$" default="$DEFAULT$" range="5;350" svd="0" size="70;-1" header="temp_defines.h">
        <action event="changed" cmd="setDef" data="BDRV_UPDATE.run=1"/>
      </spinbox>
      <text label="Reg:" size="35;-1"/>
      <math label="Register Value" define="BDRV.LS$HB_IDX$SEQ$ONOFF$IC_LS$HB_IDX$_I$PHASE$$ONOFF$_MATH" svd="0" format="%1X" formula="round(63*((BDRV.LS$HB_IDX$SEQ$ONOFF$IC_LS$HB_IDX$_I$PHASE$$ONOFF$-5)/345)^0.671)" header="temp_defines.h"/>
    </header>
  </horizontalcontainer>
</ifxmlcfg>
