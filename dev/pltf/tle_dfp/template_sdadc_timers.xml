      <action cond="SDADC.CFG0.EN$IDX$==0" event="changed" cmd="setDef" data="SDADC_$IDX$_1=#F0F0F0;SDADC_$IDX$_2=#F0F0F0;SDADC_$IDX$_3=#F0F0F0;SDADC_$IDX$_4=#F0F0F0;SDADC_$IDX$_5=#F0F0F0;SDADC_$IDX$_7=#F0F0F0;SDADC_$IDX$_8=#F0F0F0;SDADC_$IDX$_9=#F0F0F0;SDADC_$IDX$_10=#F0F0F0;SDADC_$IDX$_11=#F0F0F0;SDADC_$IDX$_12=#F0F0F0;SDADC_$IDX$_13=#F0F0F0;SDADC_$IDX$_14=#F0F0F0;SDADC_$IDX$_15=#F0F0F0;SDADC_$IDX$_6=#FFFFF0"/>
      <action cond="SDADC.CFG0.EN$IDX$==1" event="changed" cmd="setDef" data="SDADC_$IDX$_1=#000000                      ;SDADC_$IDX$_3=#AEC067;SDADC_$IDX$_4=#000000;SDADC_$IDX$_5=#84B6A7;SDADC_$IDX$_7=#AB377A;SDADC_$IDX$_8=#FFE054;SDADC_$IDX$_9=#F07F3C"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.CFG0.WFREN$IDX$==0)" event="changed" cmd="setDef" data="SDADC_$IDX$_6=#FFFFF0"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.CFG0.WFREN$IDX$==1)" event="changed" cmd="setDef" data="SDADC_$IDX$_6=#000000"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*((SDADC.RES$IDX$_INT_EN!=1).+(SDADC.IEN.RES$IDX$_EN!=1))" event="changed" cmd="setDef" data="SDADC_$IDX$_10=#FFFFF0"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.RES$IDX$_INT_EN==1).*(SDADC.IEN.RES$IDX$_EN==1)" event="changed" cmd="setDef" data="SDADC_$IDX$_10=#000000"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*((SDADC.CMP$IDX$_UP_INT_EN!=1).+(SDADC.IEN.CMP$IDX$_UP_EN!=1))" event="changed" cmd="setDef" data="SDADC_$IDX$_11=#FFFFF0"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.CMP$IDX$_UP_INT_EN==1).*(SDADC.IEN.CMP$IDX$_UP_EN==1)" event="changed" cmd="setDef" data="SDADC_$IDX$_11=#000000"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*((SDADC.CMP$IDX$_LO_INT_EN!=1).+(SDADC.IEN.CMP$IDX$_LO_EN!=1))" event="changed" cmd="setDef" data="SDADC_$IDX$_12=#FFFFF0"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.CMP$IDX$_LO_INT_EN==1).*(SDADC.IEN.CMP$IDX$_LO_EN==1)" event="changed" cmd="setDef" data="SDADC_$IDX$_12=#000000"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.INSEL_DIN$IDX$SEL_$IDX$==0)" event="changed" cmd="setDef" data="SDADC_$IDX$_2=#000000;SDADC_$IDX$_3=#AEC067;SDADC_$IDX$_14=#FFFFF0;VIS_SDADC_$IDX$_1=hidden ;VIS_SDADC_$IDX$_2=visible"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.INSEL_DIN$IDX$SEL_$IDX$!=0)" event="changed" cmd="setDef" data="SDADC_$IDX$_2=#FFFFF0;SDADC_$IDX$_3=#FFFFF0;SDADC_$IDX$_14=#000000;VIS_SDADC_$IDX$_1=visible;VIS_SDADC_$IDX$_2=hidden"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.ALTSEL_DOUT$IDX$_$IDX$==0).*(SDADC.CFG0.CICMODE$IDX$==0)" event="changed" cmd="setDef" data="SDADC_$IDX$_5=#84B6A7                      ;SDADC_$IDX$_7=#AB377A;SDADC_$IDX$_8=#FFE054;SDADC_$IDX$_9=#F07F3C                                                                     ;SDADC_$IDX$_13=#FFFFF0;SDADC_$IDX$_15=#FFFFF0;VIS_SDADC_$IDX$_3=hidden"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.ALTSEL_DOUT$IDX$_$IDX$==0).*(SDADC.CFG0.CICMODE$IDX$==1)" event="changed" cmd="setDef" data="SDADC_$IDX$_5=#84B6A7                      ;SDADC_$IDX$_7=#AB377A;SDADC_$IDX$_8=#FFE054;SDADC_$IDX$_9=#F07F3C                                                                     ;SDADC_$IDX$_13=#000000;SDADC_$IDX$_15=#FFFFF0;VIS_SDADC_$IDX$_3=hidden"/>
      <action cond="(SDADC.CFG0.EN$IDX$==1).*(SDADC.ALTSEL_DOUT$IDX$_$IDX$!=0)" event="changed" cmd="setDef" data="SDADC_$IDX$_15=#000000;VIS_SDADC_$IDX$_3=visible"/>
      <action event="changed" cmd="setDef" data="SDADC_Block.update=1"/>
    </timer>

  </verticalcontainer>
</ifxmlcfg>
